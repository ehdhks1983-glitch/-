# PromptSite 환경변수 예시 — .env.local 로 복사해서 값을 채우세요.
# 키를 비워두면 AI 코어가 자동으로 목(mock) 응답 모드로 동작합니다.

# ── AI 프로바이더 키 ──
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── (선택) 모델 ID override — 기본값은 lib/ai/config.ts ──
# ANTHROPIC_MODEL_PRIMARY=claude-opus-4-8
# ANTHROPIC_MODEL_SECONDARY=claude-sonnet-4-6
# GEMINI_MODEL_PRIMARY=gemini-3.1-pro
# GEMINI_MODEL_SECONDARY=gemini-3.5-flash
# OPENAI_TEXT_MODEL=gpt-5.1

# ── (선택) 호출 동작 override ──
# AI_TIMEOUT_MS=60000
# AI_MAX_RETRIES=1
# AI_RETRY_BACKOFF_MS=800

# ── 강제 목 모드 ──
# PROMPTSITE_MOCK=1
