# PromptSite 환경변수 예시 — .env.local 로 복사해서 값을 채우세요.
# 키를 비워두면 AI 코어가 자동으로 목(mock) 응답 모드로 동작합니다.

# ── AI 프로바이더 키 ──
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── (선택) 모델 ID override — 기본값은 lib/ai/config.ts ──
# ANTHROPIC_MODEL_PRIMARY=claude-opus-4-8
# ANTHROPIC_MODEL_SECONDARY=claude-sonnet-4-6
# GEMINI_MODEL_PRIMARY=gemini-3.1-pro
# GEMINI_MODEL_SECONDARY=gemini-3.5-flash
# OPENAI_TEXT_MODEL=gpt-5.1

# ── (선택) 호출 동작 override ──
# AI_TIMEOUT_MS=60000
# AI_MAX_RETRIES=1
# AI_RETRY_BACKOFF_MS=800

# ── 강제 목 모드 ──
# PROMPTSITE_MOCK=1

# ── Supabase (로그인/저장/게시 + Threads 큐) ──
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=        # 서버 전용(크론 발행). 절대 클라이언트 노출 금지.

# ── Threads 자동발행 (공식 Meta API) ──
# Meta 개발자 앱(developers.facebook.com)에서 발급. 값이 비면 연동은 비활성(앱은 정상 동작).
# THREADS_APP_ID=
# THREADS_APP_SECRET=
# THREADS_REDIRECT_URI=https://your-domain/api/threads/callback   # Meta 앱의 redirect URI 와 정확히 일치
# (선택) 권한/호스트/한도 override — 기본값은 lib/threads/config.ts
# THREADS_SCOPES=threads_basic,threads_content_publish
# THREADS_DAILY_CAP=10             # 계정당 하루 안전 발행 한도(Meta 상한 250보다 보수적)
# THREADS_MAX_TEXT=500
# THREADS_MAX_DRAFTS=5
# THREADS_CRON_BATCH=20
# THREADS_REFRESH_BEFORE_DAYS=7     # 만료 N일 전부터 크론이 장기 토큰 자동 갱신
# THREADS_MEDIA_POLL_ATTEMPTS=10    # 이미지 처리 완료(FINISHED) 대기 폴링 횟수
# THREADS_MEDIA_POLL_INTERVAL_MS=3000
# THREADS_PUBLISHING_STALE_MIN=10   # 'publishing' 으로 N분 이상 멈춘 글 자동 실패 처리

# ── 예약 발행 크론 보호 키 ──
# /api/threads/cron 호출 시 Authorization: Bearer <CRON_SECRET> 로 인증. (Vercel Cron 은 자동 첨부)
# CRON_SECRET=
