# ═══════════════════════════════════════════════════════════════
# SellerFit Slice 1 환경변수 (.env 파일로 복사 후 실제 값으로 수정)
# ═══════════════════════════════════════════════════════════════

# ───── 도매꾹 Open API ─────
# 발급: https://openapi.domeggook.com/main/mypage (도매꾹 로그인 후)
DOMEGGOOK_API_KEY=여기에_도매꾹_API_KEY_입력

# ───── 쿠팡 WING Open API ─────
# 발급: WING(wing.coupang.com) → 판매자정보 → 추가정보 → OpenAPI 키 발급
COUPANG_WING_VENDOR_ID=A00012345
COUPANG_WING_ACCESS_KEY=여기에_ACCESS_KEY
COUPANG_WING_SECRET_KEY=여기에_SECRET_KEY
COUPANG_WING_USER_ID=WING_로그인_아이디

# ───── 가격 계산 모드 ─────
# multiply:    도매가 × PRICING_MULTIPLIER (기본 2.5배)
# add_margin:  도매가 × (1 + PRICING_MARGIN_RATE/100) (기본 +50%)
# min_margin:  최소 마진율 보장 - 판매가 = 도매가 / (1 - PRICING_MIN_MARGIN/100)
PRICING_MODE=multiply
PRICING_MULTIPLIER=2.5
PRICING_MARGIN_RATE=50
PRICING_MIN_MARGIN=30
PRICING_ROUND_TO=100
PRICING_ADD_SHIPPING=false
PRICING_SHIPPING_FEE=2500

# ───── 배송/등록 설정 ─────
DEFAULT_DELIVERY_CHARGE=2500
DEFAULT_RETURN_CHARGE=2500
DEFAULT_DELIVERY_COMPANY=CJGLS
MAX_IMAGES=10
STOCK_QTY=999
OUTBOUND_SHIPPING_TIME_DAY=2

# 등록 후 자동으로 승인요청할지 (false=임시저장, true=즉시 승인요청)
AUTO_REQUEST_APPROVAL=false

# ───── 타임아웃 / 재시도 ─────
DOMEGGOOK_TIMEOUT=15
COUPANG_TIMEOUT=30
RETRY_COUNT=3
RETRY_DELAY=2
