# ===== App =====
APP_NAME="Centumhi License Hub"
ENVIRONMENT=dev                       # dev | prod
API_PREFIX=/api

# ===== Database =====
# SQLite for dev/early ops. Switch to PostgreSQL later (SQLAlchemy URL).
DATABASE_URL=sqlite:///./license_hub.db
# Example PostgreSQL: postgresql+psycopg://user:pass@host:5432/licensehub

# ===== JWT auth =====
JWT_SECRET_KEY=please-generate-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# ===== Seed admin (used only by `python -m app.scripts.seed_admin`) =====
SEED_ADMIN_EMAIL=admin@centumhi.co.kr
SEED_ADMIN_PASSWORD=change-this-password
SEED_ADMIN_NAME=관리자

# ===== CORS (comma separated whitelist) =====
CORS_ORIGINS=http://localhost:3000

# ===== Bot verify endpoint =====
# Allowed clock skew (seconds) for the HMAC `timestamp` field (replay protection).
VERIFY_TIMESTAMP_TOLERANCE_SEC=300

# ===== Scheduler / notifications =====
SCHEDULER_ENABLED=true
EXPIRY_NOTIFY_DAYS=3                   # notify when a license expires within N days
