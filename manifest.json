  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI 상세페이지 디렉터"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "product_analyzer.js",
        "prompt_short_dynamic.js",
        "gif_encoder.js",
        "zip_store.js",
        "content.js",
        "template_store.js",
        "fix_panel.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}