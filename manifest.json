{
  "manifest_version": 3,
  "name": "AI 상세페이지 디렉터 v21.8.24.97",
  "version": "1.5.1",
  "description": "v21.8.24.97: 쿠팡 403 통과율 개선 — 직접 fetch에 브라우저 쿠키(credentials:include) 전송(쿠팡 접속/로그인 상태면 Akamai 차단 통과 가능), 탭 보조 분석을 보이는 탭(active)으로 열어 봇차단 JS 챌린지 통과, 봇차단/보안확인 페이지 감지 시 '쿠팡 로그인 후 재시도' 명확 안내. 도매꾹 등 주문폼 휴대전화 앞자리(010/011…)·연락처·이메일 select가 '옵션 후보'로 오수집되던 문제 차단. 상세 이미지 카운트가 쿠팡 외 사이트에서 항상 0으로 뜨던 표시 개선. v96(FAQ/크롤링 오염)·v95·v94 유지.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.11st.co.kr/*",
    "https://*.auction.co.kr/*",
    "https://*.coupang.com/*",
    "https://*.domeggook.com/*",
    "https://domeggook.com/*",
    "https://*.gmarket.co.kr/*",
    "https://*.naver.com/*",
    "https://*.ssg.com/*",
    "https://*.wadiz.kr/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://*.oaiusercontent.com/*",
    "https://*.coupangcdn.com/*",
    "https://*.pstatic.net/*",
    "https://*.akamaized.net/*",
    "https://*.1688.com/*",
    "https://*.taobao.com/*",
    "https://*.tmall.com/*",
    "https://*.aliexpress.com/*",
    "https://*.aliexpress.kr/*",
    "https://*.alibaba.com/*",
    "https://*.vvic.com/*",
    "https://*.amazon.co.jp/*",
    "https://*.rakuten.co.jp/*",
    "https://*.alicdn.com/*",
    "https://link.coupang.com/*",
    "https://shopping.naver.com/*",
    "https://smartstore.naver.com/*",
    "https://www.11st.co.kr/*",
    "https://www.auction.co.kr/*",
    "https://www.coupang.com/*",
    "https://www.gmarket.co.kr/*",
    "https://www.ssg.com/*",
    "https://www.wadiz.kr/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI 상세페이지 디렉터"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "product_analyzer.js",
        "prompt_short_dynamic.js",
        "gif_encoder.js",
        "zip_store.js",
        "content.js",
        "template_store.js",
        "fix_panel.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}