{
  "manifest_version": 3,
  "name": "AI 상세페이지 디렉터 v21.8.24.107",
  "version": "1.6.1",
  "description": "상품 링크와 원본 이미지로 ChatGPT에서 상세페이지 자동 제작 — 제품 진단, 카피 기획, 섹션 이미지 생성, JPG/PDF/움짤/ZIP 출력까지. (변경 이력: CHANGELOG.md)",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.11st.co.kr/*",
    "https://*.auction.co.kr/*",
    "https://*.coupang.com/*",
    "https://*.domeggook.com/*",
    "https://domeggook.com/*",
    "https://*.gmarket.co.kr/*",
    "https://*.naver.com/*",
    "https://*.ssg.com/*",
    "https://*.wadiz.kr/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://*.oaiusercontent.com/*",
    "https://*.coupangcdn.com/*",
    "https://*.pstatic.net/*",
    "https://*.akamaized.net/*",
    "https://*.1688.com/*",
    "https://*.taobao.com/*",
    "https://*.tmall.com/*",
    "https://*.aliexpress.com/*",
    "https://*.aliexpress.kr/*",
    "https://*.alibaba.com/*",
    "https://*.vvic.com/*",
    "https://*.amazon.co.jp/*",
    "https://*.rakuten.co.jp/*",
    "https://*.alicdn.com/*",
    "https://link.coupang.com/*",
    "https://shopping.naver.com/*",
    "https://smartstore.naver.com/*",
    "https://www.11st.co.kr/*",
    "https://www.auction.co.kr/*",
    "https://www.coupang.com/*",
    "https://www.gmarket.co.kr/*",
    "https://www.ssg.com/*",
    "https://www.wadiz.kr/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI 상세페이지 디렉터"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "product_analyzer.js",
        "prompt_short_dynamic.js",
        "gif_encoder.js",
        "zip_store.js",
        "content.js",
        "template_store.js",
        "fix_panel.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}